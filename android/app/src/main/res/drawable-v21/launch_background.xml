<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Derin, gizemli ve nefes alan karanlık gradyan -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#09101a" 
                android:endColor="#020407"
                android:angle="90"
                android:type="linear" />
        </shape>
    </item>

    <!-- Tam ortada beliren AURA İkonu -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/launcher_icon" />
    </item>
</layer-list>